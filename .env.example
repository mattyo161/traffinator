# Copy this file to `.env` and adjust as needed. Everything is optional:
# with no .env at all, the app starts with a bundled Postgres and asks for
# your Google Maps API key in the browser on first launch.

# --- Google Maps -------------------------------------------------------------
# If set, the in-app setup screen is skipped and this key is always used.
# Required Google APIs on the key: "Distance Matrix API" and "Geocoding API".
GOOGLE_MAPS_API_KEY=

# --- Accounts (optional) -----------------------------------------------------
# Google "Sign in" lets users save commutes and places. Create an OAuth 2.0
# Client ID (type: Web application) in the Google Cloud Console and add your
# app origin (e.g. http://localhost:8900) to "Authorized JavaScript origins".
# Without this, the app still works fully in demo mode; sign-in is just hidden.
GOOGLE_OAUTH_CLIENT_ID=
# Apple "Sign in with Apple" is scaffolded but disabled; leave blank for now.
APPLE_OAUTH_CLIENT_ID=

# --- Route drawing (optional) ------------------------------------------------
# The map draws the real road route. With no key it uses the public OSRM demo
# server (fine for light use). For reliability, set a free OpenRouteService key
# (https://openrouteservice.org/dev/#/signup, ~2k requests/day free).
OPENROUTESERVICE_API_KEY=

# --- Web port ----------------------------------------------------------------
# The single URL you open in the browser: http://localhost:8900
APP_PORT=8900

# --- Database ----------------------------------------------------------------
# Default: the bundled Postgres container (no action needed).
# To use Supabase (or any external Postgres) instead, set DATABASE_URL to its
# connection string and enable the `cube` and `earthdistance` extensions
# (Supabase dashboard -> Database -> Extensions).
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Credentials for the bundled Postgres container (only used by the default setup)
POSTGRES_DB=commute
POSTGRES_USER=commute
POSTGRES_PASSWORD=commute

# --- Tuning ------------------------------------------------------------------
# Parallel Google Maps requests during an analysis run
ANALYSIS_MAX_WORKERS=8
# Set a fixed secret key for production-like deployments
DJANGO_SECRET_KEY=
DJANGO_DEBUG=0

# --- Rate limits (protect the paid Google endpoints) -------------------------
# DRF throttle rates ("<count>/<second|minute|hour|day>"). analyze is heaviest;
# route+geocode share the "lookup" budget; google_global is a cross-client daily
# circuit-breaker on total billable traffic. Defaults shown.
THROTTLE_ANALYZE_ANON=5/hour
THROTTLE_ANALYZE_USER=60/hour
THROTTLE_LOOKUP_ANON=30/hour
THROTTLE_LOOKUP_USER=120/hour
THROTTLE_GOOGLE_GLOBAL=2000/day
